{
  "name": "my-nuxt-starter",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "postinstall": "nuxt prepare",
    "deploy-cloudflare": "npm run build && npx wrangler deploy && npx wrangler d1 migrations apply DB --remote",
    "db:migrate": "npx wrangler d1 migrations apply DB --remote",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/content": "3.12.0",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.5.1",
    "@nuxthub/core": "0.10.7",
    "@onmax/nuxt-better-auth": "0.0.2-alpha.30",
    "better-auth": "1.5.0-beta.11",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxt/eslint": "1.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.75.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "esbuild",
      "prisma",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  }
}
