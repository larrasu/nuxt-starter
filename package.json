{
  "name": "my-nuxt-starter",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "postinstall": "nuxt prepare",
    "deploy-cloudflare": "NITRO_PRESET=cloudflare_module npm run build && npx wrangler deploy && npx wrangler d1 migrations apply DB --remote",
    "db:migrate": "npx wrangler d1 migrations apply DB --remote",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/content": "3.6.3",
    "@nuxt/image": "2.0.0",
    "@nuxt/ui": "4.4.0",
    "@nuxthub/core": "0.10.6",
    "@onmax/nuxt-better-auth": "0.0.2-alpha.19",
    "better-auth": "1.5.0-beta.11",
    "drizzle-orm": "^0.44.7",
    "nuxt": "^4.3.0",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@nuxt/eslint": "1.4.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.4",
    "wrangler": "^4.62.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "esbuild",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  }
}
